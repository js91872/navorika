{
  "buildCommand": "npm run build -- --no-lint",
  "installCommand": "npm ci --prefer-offline --no-audit --no-fund --no-optional --cache .npm",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_IGNORE_ESLINT": "true",
    "NEXT_PUBLIC_IGNORE_TYPESCRIPT": "true",
    "NEXT_DISABLE_ESLINT": "1",
    "NPM_CONFIG_CACHE": ".npm"
  },
  "installCommand": "npm ci --prefer-offline --no-audit --no-fund --cache .npm"
}
